{
  "name": "cs-revision-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:github": "VITE_BASE_PATH=/cs-revision-hub/ npm run build",
    "preview:github": "VITE_BASE_PATH=/cs-revision-hub/ vite preview",
    "preview": "vite preview",
    "seed:content": "node scripts/seed-content-items.mjs",
    "supabase:db:push": "npm run seed:content && supabase db push",
    "supabase:functions:deploy": "supabase functions deploy record-ranked-answer delete-account send-test-email --use-api",
    "supabase:advisors": "supabase db advisors --linked --fail-on none",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
